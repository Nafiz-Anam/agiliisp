  @@index([customerId])
  @@index([createdAt])
  @@map("customer_notes")
}

// Outage & Announcements
model Announcement {
  id                String   @id @default(cuid())
  title             String
  message           String
  type              String   @default("INFO") // OUTAGE, MAINTENANCE, INFO, GENERAL
  status            String   @default("DRAFT") // DRAFT, ACTIVE, RESOLVED, ARCHIVED
  affectedRouterIds String[] @map("affected_router_ids")
  startTime         DateTime? @map("start_time")
  endTime           DateTime? @map("end_time")
  estimatedResolve  DateTime? @map("estimated_resolve")
  notifyVia         String?   @map("notify_via") // SMS, EMAIL, BOTH
  notifiedCount     Int       @default(0) @map("notified_count")
  createdBy         String?   @map("created_by")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  creator User? @relation("AnnouncementCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@map("announcements")
}

// Bulk Messaging
model BulkMessage {
  id          String   @id @default(cuid())
  subject     String?
  message     String
  channel     String   // SMS, EMAIL, BOTH
  filters     Json     // { status?, routerId?, zoneId?, customerIds? }
  status      String   @default("DRAFT") // DRAFT, SENDING, COMPLETED, FAILED
  totalCount  Int      @default(0) @map("total_count")
  sentCount   Int      @default(0) @map("sent_count")
  failedCount Int      @default(0) @map("failed_count")
