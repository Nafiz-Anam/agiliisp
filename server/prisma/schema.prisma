  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  creator User? @relation("BulkMessageCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@map("bulk_messages")
}

// Invoicing
model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique @map("invoice_number")
  customerId      String        @map("customer_id")
  resellerId      String?       @map("reseller_id")
  subtotal        Decimal       @db.Decimal(12, 2)
  taxAmount       Decimal       @default(0) @map("tax_amount") @db.Decimal(12, 2)
  discountAmount  Decimal       @default(0) @map("discount_amount") @db.Decimal(12, 2)
  totalAmount     Decimal       @map("total_amount") @db.Decimal(12, 2)
  paidAmount      Decimal       @default(0) @map("paid_amount") @db.Decimal(12, 2)
  balanceDue      Decimal       @map("balance_due") @db.Decimal(12, 2)
  invoiceDate     DateTime      @default(now()) @map("invoice_date")
  dueDate         DateTime      @map("due_date")
  paidDate        DateTime?     @map("paid_date")
  sentDate        DateTime?     @map("sent_date")
  status          InvoiceStatus @default(DRAFT)
  isRecurring     Boolean       @default(false) @map("is_recurring")
  recurringPeriod String?       @map("recurring_period")
  notes           String?
  terms           String?
  footer          String?
  createdBy       String?       @map("created_by")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  customer IspCustomer   @relation(fields: [customerId], references: [id], onDelete: Restrict)
  reseller Reseller?     @relation(fields: [resellerId], references: [id], onDelete: SetNull)
  items    InvoiceItem[]
  payments Payment[]
  creator  User?         @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([resellerId])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

model InvoiceItem {
  id          String    @id @default(cuid())
  invoiceId   String    @map("invoice_id")
  description String
  packageId   String?   @map("package_id")
  quantity    Int       @default(1)
  unitPrice   Decimal   @map("unit_price") @db.Decimal(10, 2)
  totalPrice  Decimal   @map("total_price") @db.Decimal(12, 2)
  periodStart DateTime? @map("period_start")
  periodEnd   DateTime? @map("period_end")

  invoice Invoice          @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  package InternetPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@map("invoice_items")
}

// Payments
model Payment {
  id              String        @id @default(cuid())
  invoiceId       String?       @map("invoice_id")
  customerId      String        @map("customer_id")
  resellerId      String?       @map("reseller_id")
  amount          Decimal       @db.Decimal(12, 2)
  paymentMethod   PaymentMethod @map("payment_method")
  paymentDate     DateTime      @default(now()) @map("payment_date")
  status          PaymentStatus @default(PENDING)
  referenceNumber String?       @map("reference_number")
  notes           String?
  gatewayResponse Json?         @map("gateway_response")
  receiptUrl      String?       @map("receipt_url")
  verifiedBy      String?       @map("verified_by")
  verifiedAt      DateTime?     @map("verified_at")
  createdBy       String?       @map("created_by")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  invoice  Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  reseller          Reseller?          @relation(fields: [resellerId], references: [id], onDelete: SetNull)
  creator           User?              @relation(fields: [createdBy], references: [id], onDelete: SetNull)
