  @@index([customerId])
  @@index([invoiceId])
  @@index([resellerId])
  @@index([status])
  @@index([paymentDate])
  @@map("payments")
}

// Support Tickets
model SupportTicket {
  id           String         @id @default(cuid())
  ticketNumber String         @unique @map("ticket_number")
  customerId   String         @map("customer_id")
  resellerId   String?        @map("reseller_id")
  assignedTo   String?        @map("assigned_to")
  subject      String
  description  String
  category     String
  priority     TicketPriority @default(MEDIUM)
  status       TicketStatus   @default(OPEN)
  openedAt     DateTime       @default(now()) @map("opened_at")
  resolvedAt   DateTime?      @map("resolved_at")
  closedAt     DateTime?      @map("closed_at")

  customer     IspCustomer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignedUser User?         @relation("TicketAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  replies      TicketReply[]

  @@index([customerId])
  @@index([resellerId])
  @@index([status])
  @@index([priority])
  @@index([assignedTo])
  @@index([openedAt])
  @@map("support_tickets")
}

model TicketReply {
  id          String   @id @default(cuid())
  ticketId    String   @map("ticket_id")
  userId      String   @map("user_id")
  message     String
  isInternal  Boolean  @default(false) @map("is_internal")
  attachments Json?
  createdAt   DateTime @default(now()) @map("created_at")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_replies")
}

// Sync Logs for MikroTik integration
model SyncLog {
  id               String        @id @default(cuid())
  routerId         String        @map("router_id")
  syncType         String        @map("sync_type")
  direction        SyncDirection
  status           SyncStatus
  startedAt        DateTime      @default(now()) @map("started_at")
  completedAt      DateTime?     @map("completed_at")
  recordsProcessed Int           @default(0) @map("records_processed")
  recordsCreated   Int           @default(0) @map("records_created")
  recordsUpdated   Int           @default(0) @map("records_updated")
  recordsFailed    Int           @default(0) @map("records_failed")
  errorMessage     String?       @map("error_message")
  details          Json?
  triggeredBy      String?       @map("triggered_by")

  router Router @relation(fields: [routerId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [triggeredBy], references: [id], onDelete: SetNull)

  @@index([routerId])
  @@index([syncType])
  @@index([status])
  @@index([startedAt])
  @@map("sync_logs")
}

// System Settings
model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  category    String   @default("GENERAL")
  description String?
  isEncrypted Boolean  @default(false) @map("is_encrypted")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("system_settings")
}

// =============================================
// ISP Logging System
// =============================================

enum RouterLogType {
  TRAFFIC
  SYSTEM
  FIREWALL
  DHCP
  DNS
  PPPOE
  USER
  ERROR
  INFO
  WARNING
  HOTSPOT
  WIRELESS
}

enum LogSeverity {
  DEBUG
  INFO
  NOTICE
  WARNING
  ERROR
  CRITICAL
  ALERT
  EMERGENCY
}

// Router Logs - Traffic and System logs from MikroTik
model RouterLog {
  id        String        @id @default(cuid())
  routerId  String        @map("router_id")
  logType   RouterLogType @map("log_type")
  severity  LogSeverity   @default(INFO)
  timestamp DateTime      @default(now())

  // Log content
  message  String
  topic    String? // MikroTik log topic
  facility String? // System facility

  // Traffic specific fields
  srcAddress String? @map("src_address")
  dstAddress String? @map("dst_address")
  srcPort    Int?    @map("src_port")
  dstPort    Int?    @map("dst_port")
  protocol   String? // tcp, udp, icmp, etc.
  interface  String? // Network interface

  // Connection details
  connectionId String? @map("connection_id")
  customerId   String? @map("customer_id")
  username     String? // PPPoE username if applicable

  // Data usage for traffic logs
  bytesIn    BigInt? @map("bytes_in")
  bytesOut   BigInt? @map("bytes_out")
  packetsIn  Int?    @map("packets_in")
  packetsOut Int?    @map("packets_out")

  // Raw log data
  rawData Json? @map("raw_data")

  // Processing
  isProcessed Boolean   @default(false) @map("is_processed")
  processedAt DateTime? @map("processed_at")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  router   Router       @relation(fields: [routerId], references: [id], onDelete: Cascade)
  customer IspCustomer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([routerId])
  @@index([logType])
  @@index([severity])
  @@index([timestamp])
  @@index([customerId])
  @@index([username])
  @@index([isProcessed])
  @@map("router_logs")
}

// Traffic Statistics - Aggregated per customer
model TrafficStat {
  id         String @id @default(cuid())
  customerId String @map("customer_id")
  routerId   String @map("router_id")

  // Time period
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  periodType  String   @map("period_type") // HOURLY, DAILY, MONTHLY

  // Traffic data
  totalBytesIn    BigInt @default(0) @map("total_bytes_in")
  totalBytesOut   BigInt @default(0) @map("total_bytes_out")
  totalPacketsIn  Int    @default(0) @map("total_packets_in")
  totalPacketsOut Int    @default(0) @map("total_packets_out")

  // Peak usage
  peakDownloadSpeed BigInt? @map("peak_download_speed")
  peakUploadSpeed   BigInt? @map("peak_upload_speed")

  // Session data
  sessionsCount   Int @default(0) @map("sessions_count")
  totalOnlineTime Int @default(0) @map("total_online_time") // in seconds

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  customer IspCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  router   Router      @relation(fields: [routerId], references: [id], onDelete: Cascade)

  @@unique([customerId, periodType, periodStart])
  @@index([customerId])
  @@index([routerId])
  @@index([periodStart])
  @@index([periodType])
  @@map("traffic_stats")
}

// ═══════════════════════════════════════════════════════
// BTRC Compliance Logs — 6-month mandatory retention
// ═══════════════════════════════════════════════════════

// Session Log — PPPoE/Hotspot connect/disconnect events
model SessionLog {
  id            String   @id @default(cuid())
  customerId    String?  @map("customer_id")
  username      String   // PPPoE username
  routerId      String   @map("router_id")
  eventType     String   // CONNECT, DISCONNECT, AUTH_FAIL, TIMEOUT, ADMIN_KICK
  sessionId     String?  @map("session_id") // MikroTik session ID
  ipAddress     String?  @map("ip_address") // Assigned IP
  macAddress    String?  @map("mac_address") // Caller ID / MAC
  nasIp         String?  @map("nas_ip") // Router IP (NAS)
  service       String?  // pppoe, hotspot, dhcp
  uploadBytes   BigInt?  @map("upload_bytes")
  downloadBytes BigInt?  @map("download_bytes")
  sessionDuration Int?   @map("session_duration") // seconds
  disconnectReason String? @map("disconnect_reason")
  timestamp     DateTime @default(now())

  customer IspCustomer? @relation("SessionLogs", fields: [customerId], references: [id], onDelete: SetNull)
  router   Router       @relation("RouterSessionLogs", fields: [routerId], references: [id])

  @@index([customerId])
  @@index([username])
  @@index([routerId])
  @@index([ipAddress])
  @@index([timestamp])
  @@index([eventType])
  @@map("session_logs")
}

// NAT/IP Assignment Log — which customer had which IP and when
model NatLog {
  id           String   @id @default(cuid())
  customerId   String?  @map("customer_id")
  username     String
  assignedIp   String   @map("assigned_ip") // Public or private IP assigned
  publicIp     String?  @map("public_ip") // NAT public IP if different
  publicPort   Int?     @map("public_port") // NAT port range start
  macAddress   String?  @map("mac_address")
  routerId     String   @map("router_id")
  action       String   // ASSIGN, RELEASE, NAT_MAP, NAT_UNMAP
  timestamp    DateTime @default(now())

  customer IspCustomer? @relation("NatLogs", fields: [customerId], references: [id], onDelete: SetNull)
  router   Router       @relation("RouterNatLogs", fields: [routerId], references: [id])

  @@index([customerId])
  @@index([username])
  @@index([assignedIp])
  @@index([publicIp])
  @@index([timestamp])
  @@map("nat_logs")
}

// Authentication Log — all customer login attempts (success + failure)
model AuthenticationLog {
  id           String   @id @default(cuid())
  username     String
  customerId   String?  @map("customer_id")
  routerId     String   @map("router_id")
  eventType    String   // LOGIN_SUCCESS, LOGIN_FAIL, LOGOUT, SESSION_TIMEOUT
  ipAddress    String?  @map("ip_address")
  macAddress   String?  @map("mac_address")
  nasIp        String?  @map("nas_ip")
  service      String?  // pppoe, hotspot
  failReason   String?  @map("fail_reason") // wrong password, disabled, limit exceeded
  timestamp    DateTime @default(now())

  customer IspCustomer? @relation("AuthLogs", fields: [customerId], references: [id], onDelete: SetNull)
  router   Router       @relation("RouterAuthLogs", fields: [routerId], references: [id])

  @@index([username])
  @@index([customerId])
  @@index([routerId])
  @@index([timestamp])
  @@index([eventType])
  @@map("authentication_logs")
}

// App System Logs - For admin monitoring
model AppSystemLog {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())

  // Log categorization
  level     LogSeverity @default(INFO)
  category  String // AUTH, DATABASE, API, SYNC, BILLING, SECURITY, SYSTEM
  component String // Which service/component generated the log

  // Log content
  message String
  details Json? // Structured log data

  // Request context
  requestId String? @map("request_id")
  userId    String? @map("user_id")
  userRole  String? @map("user_role")
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")
  path      String? // API path or page URL
  method    String? // HTTP method

  // Error details
  errorCode  String? @map("error_code")
  errorStack String? @map("error_stack")

  // Entity references (for entity-specific logs)
  entityType String? @map("entity_type") // customer, router, invoice, etc.
  entityId   String? @map("entity_id")

  // Processing
  isRead Boolean   @default(false) @map("is_read")
  readBy String?   @map("read_by")
  readAt DateTime? @map("read_at")

  // Alerting
  isAlert   Boolean @default(false) @map("is_alert")
  alertSent Boolean @default(false) @map("alert_sent")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user       User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  readByUser User? @relation("LogReadBy", fields: [readBy], references: [id], onDelete: SetNull)

  @@index([level])
  @@index([category])
  @@index([component])
  @@index([timestamp])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([isRead])
  @@index([isAlert])
  @@map("app_system_logs")
}

// Log Retention Policy Configuration
model LogRetentionPolicy {
  id              String   @id @default(cuid())
  logType         String   @map("log_type") // ROUTER_TRAFFIC, ROUTER_SYSTEM, APP_SYSTEM
  retentionDays   Int      @map("retention_days")
  archiveEnabled  Boolean  @default(true) @map("archive_enabled")
  archiveLocation String?  @map("archive_location")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([logType])
  @@map("log_retention_policies")
}

// Alert Rules for log monitoring
model LogAlertRule {
  id          String  @id @default(cuid())
  name        String
  description String?

  // Conditions
  logType   String       @map("log_type") // Which log type to monitor
  severity  LogSeverity? @map("severity") // Minimum severity
  category  String?      @map("category")
  component String?      @map("component")
  keywords  String[]     @default([]) // Keywords to match in message

  // Threshold
  thresholdCount  Int @default(1) @map("threshold_count") // Number of occurrences
  thresholdWindow Int @default(5) @map("threshold_window") // Time window in minutes

  // Actions
  sendEmail    Boolean @default(true) @map("send_email")
  sendSms      Boolean @default(false) @map("send_sms")
  notifyAdmins Boolean @default(true) @map("notify_admins")
  webhookUrl   String? @map("webhook_url")

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("log_alert_rules")
}

// =============================================
// OLT Management System Models
// =============================================

enum OLTStatus {
  PENDING
  APPROVED
  ACTIVE
  INACTIVE
  MAINTENANCE
  ERROR
  DECOMMISSIONED
}

enum PonTechnology {
  GPON
  XG_PON
  XGS_PON
  NG_PON2
  EPON
  GEPON
}

enum PortType {
  PON
  Ethernet
  Management
  Uplink
}

enum PortStatus {
  ACTIVE
  INACTIVE
  FAULT
  DISABLED
  TESTING
}

enum OnuStatus {
  ACTIVE
  INACTIVE
  FAULT
  BLOCKED
  PROVISIONING
  UNKNOWN
}

enum AlertType {
  CPU_HIGH
  MEMORY_HIGH
  TEMPERATURE_HIGH
  POWER_FAILURE
  LINK_DOWN
  SIGNAL_LOW
  DEVICE_OFFLINE
  AUTHENTICATION_FAILURE
  CONFIGURATION_ERROR
  MAINTENANCE_REQUIRED
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
  SUPPRESSED
}

enum MaintenanceType {
  FIRMWARE_UPGRADE
  CONFIGURATION_UPDATE
  HARDWARE_REPLACEMENT
  CLEANING
  INSPECTION
  EMERGENCY
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  POSTPONED
}

model OLT {
  id           String     @id @default(cuid())
  name         String     @unique
  location     String?
  ipAddress    String     @unique @map("ip_address")
  serialNumber String?    @unique @map("serial_number")
  status       OLTStatus  @default(PENDING)
  oltBrandId   String     @map("olt_brand_id")
  oltBrand     OLTBrand   @relation(fields: [oltBrandId], references: [id])
  oltVersionId String     @map("olt_version_id")
  oltVersion   OLTVersion @relation(fields: [oltVersionId], references: [id])

  // PON Technology
  ponTechnology PonTechnology @map("pon_technology")
  maxCapacity   Int           @map("max_capacity") // Max subscribers
  currentLoad   Int           @default(0) @map("current_load")

  // Basic Monitoring
  cpuUsage     Float     @default(0) @map("cpu_usage")
  ramUsage     Float     @default(0) @map("ram_usage")
  temperature  Float?    @map("temperature")
  uptime       BigInt?   @map("uptime") // seconds
  lastSyncAt   DateTime? @map("last_sync_at")
  lastRebootAt DateTime? @map("last_reboot_at")

  // Geographic & Location Data
  latitude  Float?  @map("latitude")
  longitude Float?  @map("longitude")
  address   String?

  // Network Configuration
  managementInterface String? @map("management_interface")
  snmpCommunity       String? @map("snmp_community")
  sshPort             Int     @default(22) @map("ssh_port")

  // Status & Control
  maintenanceMode  Boolean @default(false) @map("maintenance_mode")
  autoProvisioning Boolean @default(true) @map("auto_provisioning")

  // Relations
  onus                 Onu[]
  ports                OLTPort[]
  oltAlerts            OLTAlert[]
  maintenanceSchedules MaintenanceSchedule[]

  // Metadata
  isActive  Boolean  @default(true) @map("is_active")
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  creator User?   @relation("OLTCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  user    User?   @relation(fields: [userId], references: [id])
  userId  String?

  @@index([status])
  @@index([oltBrandId])
  @@index([ponTechnology])
  @@index([isActive])
  @@map("olts")
}

model OLTBrand {
  id          String       @id @default(cuid())
  name        String       @unique
  displayName String?      @map("display_name")
  description String?
  logoUrl     String?      @map("logo_url")
  supportUrl  String?      @map("support_url")
  olts        OLT[]
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  oltversions OLTVersion[]

  @@map("olt_brands")
}

model OLTVersion {
  id            String    @id @default(cuid())
  version       String    @unique
  firmware      String?
  releaseDate   DateTime? @map("release_date")
  features      Json? // List of features
  compatibility String? // Compatibility notes
  oltBrandId    String    @map("olt_brand_id")
  oltBrand      OLTBrand  @relation(fields: [oltBrandId], references: [id], onDelete: Cascade)
  olts          OLT[]
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("olt_versions")
}

model OLTPort {
  id         String     @id @default(cuid())
  oltId      String     @map("olt_id")
  portNumber Int        @map("port_number")
  portType   PortType   @default(PON)
  status     PortStatus @default(INACTIVE)

  // ONU Association
  onuId String? @map("onu_id")
  onu   Onu?    @relation("PortONU", fields: [onuId], references: [id], onDelete: SetNull)

  // Signal Metrics
  powerLevel     Float? @map("power_level") // dBm
  signalStrength Float? @map("signal_strength") // dBm
  snr            Float? @map("snr") // Signal to Noise Ratio
  attenuation    Float? @map("attenuation") // dB

  // Traffic Metrics
  rxPower    Float?  @map("rx_power") // dBm
  txPower    Float?  @map("tx_power") // dBm
  dataRateRx BigInt? @default(0) @map("data_rate_rx") // bps
  dataRateTx BigInt? @default(0) @map("data_rate_tx") // bps

  // Configuration
  enabled Boolean @default(true)
  vlanId  Int?    @map("vlan_id")

  // Timestamps
  lastSeen        DateTime? @map("last_seen")
  lastSignalCheck DateTime? @map("last_signal_check")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  olt OLT @relation(fields: [oltId], references: [id], onDelete: Cascade)

  @@unique([oltId, portNumber])
  @@unique([onuId])
  @@index([status])
  @@index([portType])
  @@map("olt_ports")
}

model Onu {
  id           String  @id @default(cuid())
  serialNumber String  @unique @map("serial_number")
  macAddress   String? @unique @map("mac_address")

  // OLT Association
  oltId  String   @map("olt_id")
  portId String?  @map("port_id")
  olt    OLT      @relation(fields: [oltId], references: [id], onDelete: Cascade)
  port   OLTPort? @relation("PortONU")

  // Customer Association
  customerId String?      @map("customer_id")
  customer   IspCustomer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // Device Information
  onuModel        String? @map("onu_model")
  onuBrand        String? @map("onu_brand")
  firmwareVersion String? @map("firmware_version")
  hardwareVersion String? @map("hardware_version")

  // Status & Performance
  status      OnuStatus @default(ACTIVE)
  powerLevel  Float?    @map("power_level") // dBm
  distance    Float?    @map("distance") // meters
  temperature Float?    @map("temperature")

  // Traffic Metrics
  dataRx     BigInt  @default(0) @map("data_rx") // bytes
  dataTx     BigInt  @default(0) @map("data_tx") // bytes
  dataRateRx BigInt? @default(0) @map("data_rate_rx") // bps
  dataRateTx BigInt? @default(0) @map("data_rate_tx") // bps

  // Configuration
  vlanId       Int?    @map("vlan_id")
  speedProfile String? @map("speed_profile")
  qosProfile   String? @map("qos_profile")

  // Features
  autoProvisioned Boolean @default(false) @map("auto_provisioned")
  remoteAccess    Boolean @default(false) @map("remote_access")

  // Geographic Data
  latitude         Float?    @map("latitude")
  longitude        Float?    @map("longitude")
  address          String?
  installationDate DateTime? @map("installation_date")

  // Timestamps
  lastSyncAt DateTime? @map("last_sync_at")
  lastSeen   DateTime? @map("last_seen")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([oltId])
  @@index([customerId])
  @@index([status])
  @@index([macAddress])
  @@map("onus")
}

// Core Support Models
model OLTAlert {
  id             String        @id @default(cuid())
  oltId          String        @map("olt_id")
  alertType      AlertType     @map("alert_type")
  severity       AlertSeverity @default(MEDIUM)
  title          String
  description    String
  value          Float?
  threshold      Float?
  status         AlertStatus   @default(ACTIVE)
  acknowledged   Boolean       @default(false) @map("acknowledged")
  acknowledgedBy String?       @map("acknowledged_by")
  acknowledgedAt DateTime?     @map("acknowledged_at")
  resolvedAt     DateTime?     @map("resolved_at")
  createdAt      DateTime      @default(now()) @map("created_at")

  olt OLT @relation(fields: [oltId], references: [id], onDelete: Cascade)

  @@index([oltId, status])
  @@index([severity])
  @@map("olt_alerts")
}

model MaintenanceSchedule {
  id           String            @id @default(cuid())
  oltId        String            @map("olt_id")
  title        String
  description  String?
  scheduledFor DateTime          @map("scheduled_for")
  duration     Int               @map("duration") // minutes
  type         MaintenanceType   @map("maintenance_type")
  status       MaintenanceStatus @default(SCHEDULED)
  performedBy  String?           @map("performed_by")
  notes        String?
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  olt OLT @relation(fields: [oltId], references: [id], onDelete: Cascade)

  @@index([oltId, status])
  @@index([scheduledFor])
  @@map("maintenance_schedules")
}

// ═══════════════════════════════════════════════════
// Inventory Management
// ═══════════════════════════════════════════════════

model InventoryCategory {
  id          String          @id @default(cuid())
  name        String          @unique
  description String?
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  items InventoryItem[]

  @@map("inventory_categories")
}

enum TransactionType {
  PURCHASE_IN
  DEPLOY_OUT
  RETURN_IN
  DAMAGE
  REPAIR_SEND
  REPAIR_RETURN
  ADJUSTMENT
  SALE
  DECOMMISSION
}

enum ItemCondition {
  NEW
  GOOD
  FAIR
  DAMAGED
  DEFECTIVE
  DECOMMISSIONED
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model InventoryItem {
  id                String            @id @default(cuid())
  name              String
  sku               String            @unique
  categoryId        String            @map("category_id")
  brand             String?
  model             String?
  description       String?
  unitCost          Decimal           @default(0) @map("unit_cost") @db.Decimal(10, 2)
  sellingPrice      Decimal?          @map("selling_price") @db.Decimal(10, 2)
  minStockThreshold Int               @default(5) @map("min_stock_threshold")
  totalQuantity     Int               @default(0) @map("total_quantity")
  inStockCount      Int               @default(0) @map("in_stock_count")
  deployedCount     Int               @default(0) @map("deployed_count")
  damagedCount      Int               @default(0) @map("damaged_count")
  inRepairCount     Int               @default(0) @map("in_repair_count")
  isActive          Boolean           @default(true) @map("is_active")
  createdBy         String?           @map("created_by")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  category          InventoryCategory      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  creator           User?                  @relation("InventoryItemCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  transactions      InventoryTransaction[]
  purchaseOrderItems PurchaseOrderItem[]

  @@index([categoryId])
  @@index([sku])
  @@index([isActive])
  @@map("inventory_items")
}

model InventoryTransaction {
  id              String          @id @default(cuid())
  itemId          String          @map("item_id")
  type            TransactionType
  quantity        Int
  previousQty     Int             @map("previous_qty")
  newQty          Int             @map("new_qty")
  condition       ItemCondition   @default(NEW)
  customerId      String?         @map("customer_id")
  purchaseOrderId String?         @map("purchase_order_id")
  reference       String?
  notes           String?
  performedBy     String?         @map("performed_by")
  createdAt       DateTime        @default(now()) @map("created_at")

  item          InventoryItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  customer      IspCustomer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  performer     User?          @relation("TransactionPerformer", fields: [performedBy], references: [id], onDelete: SetNull)

  @@index([itemId])
  @@index([type])
  @@index([customerId])
  @@index([createdAt])
  @@map("inventory_transactions")
}

model Supplier {
  id          String   @id @default(cuid())
  name        String
  contactName String?  @map("contact_name")
  email       String?
  phone       String?
  address     String?
  city        String?
  website     String?
  taxId       String?  @map("tax_id")
  notes       String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  purchaseOrders PurchaseOrder[]

  @@index([isActive])
  @@map("suppliers")
}

model PurchaseOrder {
  id              String              @id @default(cuid())
  orderNumber     String              @unique @map("order_number")
  supplierId      String?             @map("supplier_id")
  supplier        String              // kept for backward compat / display name
  supplierContact String?             @map("supplier_contact")
  supplierEmail   String?             @map("supplier_email")
  status          PurchaseOrderStatus @default(DRAFT)
  orderDate       DateTime            @default(now()) @map("order_date")
  expectedDate    DateTime?           @map("expected_date")
  receivedDate    DateTime?           @map("received_date")
  totalAmount     Decimal             @default(0) @map("total_amount") @db.Decimal(12, 2)
  notes           String?
  createdBy       String?             @map("created_by")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  supplierRef  Supplier?              @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  items        PurchaseOrderItem[]
  transactions InventoryTransaction[]
  creator      User?                  @relation("PurchaseOrderCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String  @id @default(cuid())
  purchaseOrderId  String  @map("purchase_order_id")
  inventoryItemId  String  @map("inventory_item_id")
  quantity         Int
  unitCost         Decimal @map("unit_cost") @db.Decimal(10, 2)
  totalCost        Decimal @map("total_cost") @db.Decimal(12, 2)
  receivedQuantity Int     @default(0) @map("received_quantity")

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([inventoryItemId])
  @@map("purchase_order_items")
}

// ═══════════════════════════════════════════════════════
// Network Monitoring (SNMP)
// ═══════════════════════════════════════════════════════

enum MonitoredDeviceType {
  ROUTER
  OLT
}

enum MetricType {
  CPU_USAGE
  MEMORY_USAGE
  UPTIME
  INTERFACE_IN_BYTES
  INTERFACE_OUT_BYTES
  INTERFACE_STATUS
  TEMPERATURE
  DISK_USAGE
}

model DeviceMetric {
  id            String     @id @default(cuid())
  deviceId      String     @map("device_id")
  deviceType    MonitoredDeviceType @map("device_type")
  metricType    MetricType @map("metric_type")
  value         Float
  unit          String?
  interfaceName String?    @map("interface_name")
  collectedAt   DateTime   @default(now()) @map("collected_at")

  @@index([deviceId, metricType, collectedAt])
  @@index([deviceType, collectedAt])
  @@index([collectedAt])
  @@map("device_metrics")
}

model DeviceAlert {
  id             String        @id @default(cuid())
  deviceId       String        @map("device_id")
  deviceType     DeviceType    @map("device_type")
  alertType      AlertType     @map("alert_type")
  severity       AlertSeverity @default(MEDIUM)
  title          String
  description    String
  value          Float?
  threshold      Float?
  status         AlertStatus   @default(ACTIVE)
  acknowledgedBy String?       @map("acknowledged_by")
  acknowledgedAt DateTime?     @map("acknowledged_at")
  resolvedAt     DateTime?     @map("resolved_at")
  createdAt      DateTime      @default(now()) @map("created_at")

  @@index([deviceId, deviceType, status])
  @@index([severity])
  @@index([status, createdAt])
  @@map("device_alerts")
}

model MonitoringConfig {
  id              String      @id @default(cuid())
  deviceId        String?     @map("device_id")
  deviceType      MonitoredDeviceType? @map("device_type")
  pollingInterval Int         @default(300)  @map("polling_interval")
  cpuThreshold    Float       @default(80)   @map("cpu_threshold")
  memoryThreshold Float       @default(90)   @map("memory_threshold")
  tempThreshold   Float?      @default(75)   @map("temp_threshold")
  retentionDays   Int         @default(30)   @map("retention_days")
  isEnabled       Boolean     @default(true) @map("is_enabled")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  @@unique([deviceId, deviceType])
  @@map("monitoring_configs")
}

// ═══════════════════════════════════════════════════════
// Expense Tracking & Financial
// ═══════════════════════════════════════════════════════

enum BillingType {
  PREPAID
  POSTPAID
}

enum ExpenseCategory {
  SALARY
  RENT
  UTILITIES
  BANDWIDTH
  EQUIPMENT
  MAINTENANCE
  MARKETING
  TRANSPORT
  TAXES
  LICENSES
  INSURANCE
  OTHER
}

model Expense {
  id            String          @id @default(cuid())
  category      ExpenseCategory
  amount        Decimal         @db.Decimal(12, 2)
  description   String
  vendor        String?
  referenceNo   String?         @map("reference_no")
  expenseDate   DateTime        @map("expense_date")
  paymentMethod String?         @map("payment_method")
  isRecurring   Boolean         @default(false) @map("is_recurring")
  recurringDay  Int?            @map("recurring_day")
  notes         String?
  createdBy     String?         @map("created_by")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  creator User? @relation("ExpenseCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([expenseDate])
  @@map("expenses")
}

// ═══════════════════════════════════════════════════════
// Zone / Area Management
// ═══════════════════════════════════════════════════════

model Zone {
  id          String   @id @default(cuid())
  name        String   @unique
  parentId    String?  @map("parent_id")
  division    String?
  district    String?
  upazila     String?
  area        String?  // Local area / locality name (e.g. Khalishpur, Sonadanga)
  description String?
  coverage    String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parent   Zone?         @relation("ZoneHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Zone[]        @relation("ZoneHierarchy")
  customers IspCustomer[]
  collectors Collector[]
  resellers  Reseller[]

  @@index([parentId])
  @@index([division, district])
  @@map("zones")
}

// ═══════════════════════════════════════════════════════
// Collector / Field Agent Management
// ═══════════════════════════════════════════════════════

model Collector {
  id          String   @id @default(cuid())
  userId      String?  @unique @map("user_id")
  name        String
  phone       String
  email       String?
  zoneId      String?  @map("zone_id")
  commissionRate Decimal? @map("commission_rate") @db.Decimal(5, 2)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User?         @relation("CollectorUser", fields: [userId], references: [id], onDelete: SetNull)
  zone        Zone?         @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  customers   IspCustomer[]
  collections Collection[]

  @@index([zoneId])
  @@map("collectors")
}

model Collection {
  id            String   @id @default(cuid())
  collectorId   String   @map("collector_id")
  customerId    String   @map("customer_id")
  invoiceId     String?  @map("invoice_id")
  amount        Decimal  @db.Decimal(12, 2)
  paymentMethod String   @default("CASH") @map("payment_method")
  referenceNo   String?  @map("reference_no")
  collectedAt   DateTime @default(now()) @map("collected_at")
  status        String   @default("PENDING")
  reconciledAt  DateTime? @map("reconciled_at")
  reconciledBy  String?  @map("reconciled_by")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")

  collector Collector @relation(fields: [collectorId], references: [id], onDelete: Restrict)

  @@index([collectorId])
  @@index([customerId])
  @@index([status])
  @@index([collectedAt])
  @@map("collections")
}

// ═══════════════════════════════════════════════════════
// SMS Notifications
// ═══════════════════════════════════════════════════════

model SmsLog {
  id          String   @id @default(cuid())
  phone       String
  message     String
  type        String
  status      String   @default("PENDING")
  provider    String?
  providerRef String?  @map("provider_ref")
  errorMsg    String?  @map("error_msg")
  sentAt      DateTime? @map("sent_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([phone])
  @@index([status])
  @@index([createdAt])
  @@map("sms_logs")
}

// ═══════════════════════════════════════════════════════
// Mobile Payment (bKash/Nagad) Transactions
// ═══════════════════════════════════════════════════════

model MobilePayment {
  id              String   @id @default(cuid())
  provider        String
  transactionId   String   @unique @map("transaction_id")
  senderNumber    String   @map("sender_number")
  receiverNumber  String   @map("receiver_number")
  amount          Decimal  @db.Decimal(12, 2)
  fee             Decimal? @db.Decimal(10, 2)
  customerId      String?  @map("customer_id")
  invoiceId       String?  @map("invoice_id")
  status          String   @default("PENDING")
  rawPayload      Json?    @map("raw_payload")
  matchedAt       DateTime? @map("matched_at")
  processedAt     DateTime? @map("processed_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([senderNumber])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@map("mobile_payments")
}

// ═══════════════════════════════════════════════════════
// IP Subnet / Pool Management
// ═══════════════════════════════════════════════════════

enum IpPoolType {
  PPPOE
  DHCP
  STATIC
  CGNAT
  MANAGEMENT
}

model IpPool {
  id            String     @id @default(cuid())
  name          String
  network       String                          // e.g. "10.10.1.0"
  cidr          Int                             // e.g. 24
  gateway       String?
  dnsServers    String?    @map("dns_servers")  // comma-separated
  poolType      IpPoolType @default(PPPOE) @map("pool_type")
  routerId      String?    @map("router_id")
  vlanId        Int?       @map("vlan_id")
  totalIps      Int        @map("total_ips")
  usedIps       Int        @default(0) @map("used_ips")
  reservedIps   Int        @default(0) @map("reserved_ips")
  description   String?
  isActive      Boolean    @default(true) @map("is_active")
  syncToRouter  Boolean    @default(false) @map("sync_to_router")
  mikrotikPool  String?    @map("mikrotik_pool") // pool name on MikroTik
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  assignments   IpAssignment[]

  @@unique([network, cidr])
  @@index([routerId])
  @@index([poolType])
  @@map("ip_pools")
}

enum IpAssignmentStatus {
  ACTIVE
  RESERVED
  RELEASED
  BLOCKED
}

model IpAssignment {
  id          String             @id @default(cuid())
  poolId      String             @map("pool_id")
  ipAddress   String             @map("ip_address")
  customerId  String?            @map("customer_id")
  status      IpAssignmentStatus @default(ACTIVE)
  description String?
  assignedAt  DateTime           @default(now()) @map("assigned_at")
  releasedAt  DateTime?          @map("released_at")

  pool IpPool @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@unique([poolId, ipAddress])
  @@index([customerId])
  @@index([status])
  @@map("ip_assignments")
}
