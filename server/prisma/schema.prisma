// Customer Notes / Interaction Log
model CustomerNote {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  userId     String?  @map("user_id")
  type       String   @default("NOTE") // NOTE, CALL, VISIT, COMPLAINT, FOLLOW_UP, SYSTEM
