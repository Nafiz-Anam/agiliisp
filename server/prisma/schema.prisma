  LOGIN_ALERT
  PASSWORD_CHANGE
  EMAIL_VERIFICATION
  TWO_FACTOR_SETUP
  ACCOUNT_LOCKED
  SECURITY_ALERT
  SYSTEM_UPDATE
  WELCOME
  // ISP Business notifications
  INVOICE_CREATED
  INVOICE_OVERDUE
  PAYMENT_RECEIVED
  TICKET_CREATED
  TICKET_REPLIED
  TICKET_ASSIGNED
  TICKET_RESOLVED
  CUSTOMER_ACTIVATED
  CUSTOMER_SUSPENDED
  CUSTOMER_EXPIRED
  DEVICE_ALERT
  DEVICE_RESOLVED
  BANDWIDTH_WARNING
  BANDWIDTH_CRITICAL
  CUSTOMER_ONLINE
  CUSTOMER_OFFLINE
  ANNOUNCEMENT
}

enum DeviceType {
  MOBILE
  TABLET
  DESKTOP
  UNKNOWN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum OtpType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

