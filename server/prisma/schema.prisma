// Inventory & Order Management
// =============================================

// =============================================
// ISP CRM System Models
// =============================================

enum ConnectionType {
  PPPOE
  STATIC_IP
  DHCP
  HOTSPOT
}

enum CustomerStatus {
  ACTIVE
  SUSPENDED
  TERMINATED
  PENDING_ACTIVATION
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  MOBILE_MONEY
  CREDIT_CARD
  DEBIT_CARD
  CHECK
  ONLINE_PAYMENT
  AGENT_COLLECTED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  PENDING_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RouterStatus {
  ONLINE
  OFFLINE
  WARNING
  MAINTENANCE
}

enum SyncDirection {
  MIKROTIK_TO_CRM
  CRM_TO_MIKROTIK
  BIDIRECTIONAL
}

enum SyncStatus {
  PENDING
  IN_PROGRESS
  SUCCESS
  PARTIAL_SUCCESS
  FAILED
}

// Router Management
model Router {
  id              String       @id @default(cuid())
  name            String       @unique
  host            String
  port            Int          @default(8728)
  useSSL          Boolean      @default(false) @map("use_ssl")
  username        String
  password        String
  apiVersion      String?      @map("api_version")
  status          RouterStatus @default(OFFLINE)
  lastConnectedAt DateTime?    @map("last_connected_at")
  lastSyncAt      DateTime?    @map("last_sync_at")
  syncEnabled     Boolean      @default(true) @map("sync_enabled")
  snmpCommunity   String?      @map("snmp_community")
  snmpVersion     Int          @default(2) @map("snmp_version")
  location        String?
  description     String?
  isActive        Boolean      @default(true) @map("is_active")
  createdBy       String?      @map("created_by")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  packages     InternetPackage[]
  customers    IspCustomer[]
  syncLogs     SyncLog[]
  creator      User?             @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  routerLogs   RouterLog[]
  trafficStats TrafficStat[]

  // Compliance log relations
  sessionLogs        SessionLog[]        @relation("RouterSessionLogs")
  natLogs            NatLog[]            @relation("RouterNatLogs")
  authenticationLogs AuthenticationLog[] @relation("RouterAuthLogs")

  @@map("routers")
}

// Internet Packages/Bandwidth Plans
model InternetPackage {
  id            String    @id @default(cuid())
  name          String
  mikrotikId    String?   @map("mikrotik_id")
  routerId      String    @map("router_id")
  downloadSpeed     Int       @map("download_speed")
  uploadSpeed       Int       @map("upload_speed")
  bdixDownloadSpeed Int?      @map("bdix_download_speed")
  bdixUploadSpeed   Int?      @map("bdix_upload_speed")
  dataLimit         Int?      @map("data_limit")
  burstDownload     Int?      @map("burst_download")
  burstUpload       Int?      @map("burst_upload")
  threshold     Int?      @map("threshold")
  burstTime     Int?      @map("burst_time")
  priority      Int       @default(8)
  price         Decimal   @db.Decimal(10, 2)
  costPrice     Decimal?  @map("cost_price") @db.Decimal(10, 2)
  description   String?
  isActive      Boolean   @default(true) @map("is_active")
  isPublic      Boolean   @default(true) @map("is_public")
  syncEnabled   Boolean   @default(true) @map("sync_enabled")
  lastSyncAt    DateTime? @map("last_sync_at")
  createdBy     String?   @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  router       Router        @relation(fields: [routerId], references: [id], onDelete: Restrict)
  customers    IspCustomer[]
  invoiceItems InvoiceItem[]
  creator      User?         @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([routerId, name])
  @@index([routerId])
  @@index([isActive])
  @@map("internet_packages")
}

// Reseller Management
model Reseller {
  id                    String   @id @default(cuid())
  userId                String   @unique @map("user_id")
  parentResellerId      String?  @map("parent_reseller_id")
  level                 String   @default("MASTER") // MASTER, AREA, SUB
  zoneId                String?  @map("zone_id")
  businessName          String   @map("business_name")
  businessRegistration  String?  @map("business_registration")
  taxId                 String?  @map("tax_id")
  commissionRate        Decimal  @default(0) @map("commission_rate") @db.Decimal(5, 2)
  creditLimit           Decimal? @map("credit_limit") @db.Decimal(12, 2)
  currentBalance        Decimal  @default(0) @map("current_balance") @db.Decimal(12, 2)
  markupPercentage      Decimal  @default(0) @map("markup_percentage") @db.Decimal(5, 2)
  canCreatePackages     Boolean  @default(false) @map("can_create_packages")
  canCreateCustomers    Boolean  @default(true) @map("can_create_customers")
  canCreateSubResellers Boolean  @default(false) @map("can_create_sub_resellers")
  whiteLabelEnabled     Boolean  @default(false) @map("white_label_enabled")
  companyLogo                String?  @map("company_logo")
  businessRegistrationUrl    String?  @map("business_registration_url")
  tinDocumentUrl             String?  @map("tin_document_url")
  primaryColor               String?  @map("primary_color")
  supportPhone          String?  @map("support_phone")
  supportEmail          String?  @map("support_email")
  notes                 String?
  isActive              Boolean  @default(true) @map("is_active")
  createdBy             String?  @map("created_by")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user             User          @relation("UserResellerProfile", fields: [userId], references: [id], onDelete: Cascade)
  parentReseller   Reseller?     @relation("ResellerHierarchy", fields: [parentResellerId], references: [id], onDelete: SetNull)
  childResellers   Reseller[]    @relation("ResellerHierarchy")
  zone             Zone?         @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  customers        IspCustomer[]
  invoices         Invoice[]
  payments         Payment[]
  commissionRecords CommissionRecord[]
  payouts          ResellerPayout[]
  creator          User?         @relation("ResellerCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([parentResellerId])
  @@index([level])
  @@index([zoneId])
  @@map("resellers")
}

// Commission Records — tracks every commission transaction
model CommissionRecord {
  id                String   @id @default(cuid())
  resellerId        String   @map("reseller_id")
  paymentId         String   @map("payment_id")
  invoiceId         String   @map("invoice_id")
  customerId        String   @map("customer_id")
  sourceResellerId  String?  @map("source_reseller_id")
  sourceType        String   // PAYMENT (direct), CASCADED (from child reseller)
  commissionRate    Decimal  @map("commission_rate") @db.Decimal(5, 2)
  baseAmount        Decimal  @map("base_amount") @db.Decimal(12, 2)
  commissionAmount  Decimal  @map("commission_amount") @db.Decimal(12, 2)
  resellerLevel     String   @map("reseller_level") // MASTER, AREA, SUB
  notes             String?
  createdAt         DateTime @default(now()) @map("created_at")

  reseller Reseller @relation(fields: [resellerId], references: [id], onDelete: Cascade)
  payment  Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([resellerId])
  @@index([paymentId])
  @@index([customerId])
  @@index([createdAt])
  @@map("commission_records")
}

// Reseller Payouts — payout requests and settlements
model ResellerPayout {
  id              String    @id @default(cuid())
  resellerId      String    @map("reseller_id")
  amount          Decimal   @db.Decimal(12, 2)
  payoutMethod    String    @map("payout_method") // BANK_TRANSFER, BKASH, NAGAD, CASH
  status          String    @default("PENDING") // PENDING, APPROVED, REJECTED, COMPLETED
  referenceNumber String?   @map("reference_number")
  accountDetails  Json?     @map("account_details")
  requestedAt     DateTime  @default(now()) @map("requested_at")
  processedAt     DateTime? @map("processed_at")
  processedBy     String?   @map("processed_by")
  rejectionReason String?   @map("rejection_reason")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  reseller  Reseller @relation(fields: [resellerId], references: [id], onDelete: Cascade)
  processor User?    @relation("PayoutProcessor", fields: [processedBy], references: [id], onDelete: SetNull)

  @@index([resellerId])
  @@index([status])
  @@map("reseller_payouts")
}

// ISP Customers
model IspCustomer {
  id               String         @id @default(cuid())
  userId           String?        @unique @map("user_id")
  mikrotikId       String?        @map("mikrotik_id")
  resellerId       String?        @map("reseller_id")
  routerId         String         @map("router_id")
  packageId        String         @map("package_id")
  username         String         @unique
  password         String?
  connectionType   ConnectionType @default(PPPOE) @map("connection_type")
  ipAddress        String?        @map("ip_address")
  macAddress       String?        @map("mac_address")
  serviceName      String?        @map("service_name")
  fullName         String         @map("full_name")
  email            String?
  phone            String?
  phoneSecondary   String?        @map("phone_secondary")
  address          String?
  city             String?
  state            String?
  zipCode          String?        @map("zip_code")
  country          String?
  gpsCoordinates   String?        @map("gps_coordinates")
  billingAddress   String?        @map("billing_address")
  billingCycle     Int            @default(1) @map("billing_cycle")
  nextBillingDate  DateTime?      @map("next_billing_date")
  gracePeriod      Int            @default(3) @map("grace_period")
  autoSuspend      Boolean        @default(true) @map("auto_suspend")
  autoSuspendDays  Int            @default(7) @map("auto_suspend_days")
  customPrice      Decimal?       @map("custom_price") @db.Decimal(10, 2)
  profileImageUrl  String?        @map("profile_image_url")
  // Bangladesh-specific fields
  nidNumber        String?        @map("nid_number")
  nidFrontUrl      String?        @map("nid_front_url")
  nidBackUrl       String?        @map("nid_back_url")
  agreementUrl     String?        @map("agreement_url")
  zoneId           String?        @map("zone_id")
  collectorId      String?        @map("collector_id")
  billingType      BillingType    @default(POSTPAID) @map("billing_type")
  expiryDate       DateTime?      @map("expiry_date")
  connectionPoint  String?        @map("connection_point")
  floor            String?
  building         String?
  maxDevices       Int?           @map("max_devices")
  status           CustomerStatus @default(PENDING_ACTIVATION)
  isOnline         Boolean        @default(false) @map("is_online")
  lastOnlineAt     DateTime?      @map("last_online_at")
  installationDate DateTime?      @map("installation_date")
  terminationDate  DateTime?      @map("termination_date")
  suspensionReason String?        @map("suspension_reason")
  dataUsed         BigInt         @default(0) @map("data_used")
  dataLimit        BigInt?        @map("data_limit")
  lastSyncAt       DateTime?      @map("last_sync_at")
  notes            String?
  isActive         Boolean        @default(true) @map("is_active")
  createdBy        String?        @map("created_by")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  user         User?           @relation("UserCustomerProfile", fields: [userId], references: [id], onDelete: SetNull)
  reseller     Reseller?       @relation(fields: [resellerId], references: [id], onDelete: SetNull)
  router       Router          @relation(fields: [routerId], references: [id], onDelete: Restrict)
  package      InternetPackage @relation(fields: [packageId], references: [id], onDelete: Restrict)
  zone         Zone?           @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  collector    Collector?      @relation(fields: [collectorId], references: [id], onDelete: SetNull)
  invoices     Invoice[]
  tickets      SupportTicket[]
  creator      User?           @relation("CustomerCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  routerLogs              RouterLog[]
  trafficStats            TrafficStat[]
  onus                    Onu[]
  inventoryTransactions   InventoryTransaction[]

  @@index([resellerId])
  @@index([routerId])
  @@index([packageId])
  @@index([status])
  @@index([isActive])
  @@index([zoneId])
  @@index([collectorId])
  @@map("isp_customers")

  // Compliance log relations
  sessionLogs        SessionLog[]        @relation("SessionLogs")
  natLogs            NatLog[]            @relation("NatLogs")
